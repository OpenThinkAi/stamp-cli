#!/bin/sh
#
# stamp-server-pubkey — print the public half of the stamp server's
# GitHub mirror-push deploy key.
#
# Output: a single OpenSSH-format public key line, suitable for
# registering as a deploy key on a GitHub repo via
# POST /repos/:o/:r/keys.
#
# Run via:
#   ssh git@<host> stamp-server-pubkey
#
# The keypair is auto-generated by entrypoint.sh on the server's first
# boot of the deploy-key-aware image. If the key file is missing here,
# the most likely cause is that the operator hasn't redeployed the
# stamp-server image since the deploy-key feature shipped. The script
# prints a clear note in that case instead of silently producing empty
# output — empty stdout from this command would be a misleading "exists
# but empty" signal to the client.
#
set -e

KEY_FILE=/srv/git/.ssh-client-keys/github_ed25519.pub

if [ ! -f "$KEY_FILE" ]; then
  echo "stamp-server-pubkey: $KEY_FILE not found." >&2
  echo "stamp-server-pubkey: the stamp-server image likely predates the deploy-key feature." >&2
  echo "stamp-server-pubkey: redeploy the container to auto-generate the keypair." >&2
  exit 1
fi

cat "$KEY_FILE"
