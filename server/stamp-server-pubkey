#!/bin/sh
#
# stamp-server-pubkey — print the public half of a stamp-server-managed
# GitHub mirror-push deploy key.
#
# Two modes:
#
#   ssh git@<host> stamp-server-pubkey
#       Print the LEGACY shared key (/srv/git/.ssh-client-keys/
#       github_ed25519.pub). Kept for back-compat — older operators and
#       scripts that called this command before the per-repo key feature
#       existed continue to get the same output.
#
#   ssh git@<host> stamp-server-pubkey <owner>/<repo>
#       Print the per-repo key for the named GitHub mirror. Lazily
#       generated on first request via sudo + stamp-ensure-repo-key (the
#       only privilege-escalation path the git user has, and it refuses
#       to overwrite existing keys). Subsequent requests for the same
#       repo are cache hits — the file persists across container reboots
#       on the /srv/git volume.
#
# Output is a single OpenSSH-format public-key line on stdout, suitable
# for piping into `gh api -X POST /repos/:o/:r/keys --field key=@-`. No
# trailing decoration; trim downstream if necessary. The trailing
# newline from `cat` is intentional and matches what every other CLI
# tool that pipes pubkeys emits.
#
# Why this command exists rather than `cat ~/.ssh/<key>.pub` from the
# operator's laptop: the keypair lives only on the stamp server (the
# private half MUST never leave). The pubkey is the only half safe to
# transmit, and serving it via an SSH-authenticated wrapper means no
# additional surface beyond what's already required to push.
#
set -e

KEY_DIR=/srv/git/.ssh-client-keys
SPEC="${1:-}"

if [ -z "$SPEC" ]; then
  # Back-compat path: emit the legacy shared key. Same behavior as
  # the pre-per-repo-keys version of this wrapper.
  LEGACY_PUB="$KEY_DIR/github_ed25519.pub"
  if [ ! -f "$LEGACY_PUB" ]; then
    echo "stamp-server-pubkey: $LEGACY_PUB not found." >&2
    echo "stamp-server-pubkey: the stamp-server image likely predates the deploy-key feature." >&2
    echo "stamp-server-pubkey: redeploy the container to auto-generate the keypair." >&2
    exit 1
  fi
  cat "$LEGACY_PUB"
  exit 0
fi

# Per-repo path. Validate the spec shape locally (defense in depth — the
# helper validates again, but rejecting bad input here gives a faster,
# clearer error and avoids spawning sudo for known-invalid specs).
case "$SPEC" in
  -*)
    echo "stamp-server-pubkey: spec must not start with '-': $SPEC" >&2
    exit 2 ;;
  *..*)
    echo "stamp-server-pubkey: spec must not contain '..': $SPEC" >&2
    exit 2 ;;
esac
case "$SPEC" in
  */*) : ;;
  *)
    echo "stamp-server-pubkey: spec must be <owner>/<repo>: $SPEC" >&2
    exit 2 ;;
esac
case "$SPEC" in
  */*/*)
    echo "stamp-server-pubkey: spec must contain exactly one '/': $SPEC" >&2
    exit 2 ;;
esac
case "$SPEC" in
  /*|*/)
    echo "stamp-server-pubkey: owner and repo halves must both be non-empty: $SPEC" >&2
    exit 2 ;;
esac
case "$SPEC" in
  *[!A-Za-z0-9./_-]*)
    echo "stamp-server-pubkey: spec contains invalid characters: $SPEC" >&2
    exit 2 ;;
esac

SANITIZED=$(printf '%s' "$SPEC" | tr '/' '_')
PUB_PATH="$KEY_DIR/${SANITIZED}_ed25519.pub"

if [ ! -f "$PUB_PATH" ]; then
  # Lazy generation. The helper is root-owned, configured for NOPASSWD
  # invocation by the git user, and refuses to overwrite existing files
  # — so this is the ONLY code path that mints a new per-repo keypair,
  # and it's safe to call repeatedly (subsequent calls are no-ops after
  # the file exists). sudo -n: never prompt, fail immediately if not
  # configured. The stderr from the helper surfaces directly to the
  # ssh client so configuration mistakes are debuggable from the
  # operator's terminal.
  sudo -n /usr/local/sbin/stamp-ensure-repo-key "$SPEC" >&2
fi

if [ ! -f "$PUB_PATH" ]; then
  # Helper ran (or failed silently — sudo error already surfaced above)
  # but the public file still isn't there. Either generation failed or
  # the file was deleted out from under us between the two checks.
  # Either way, refuse rather than emit an empty stdout that the client
  # would helpfully POST to GitHub as a malformed deploy key.
  echo "stamp-server-pubkey: $PUB_PATH still missing after ensure-key; check server logs" >&2
  exit 1
fi

cat "$PUB_PATH"
