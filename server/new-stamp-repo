#!/bin/sh
#
# new-stamp-repo — one-line repo provisioning on a running stamp server.
#
# Usage (over SSH):
#   ssh git@<host> new-stamp-repo <name>                          # placeholder seed
#   ssh git@<host> new-stamp-repo <name> <seed-stamp-dir>         # custom .stamp/ seed
#   ssh git@<host> new-stamp-repo <name> --from-tarball <path>    # brownfield migration
#
# Creates /srv/git/<name>.git with the stamp-verify hook installed and the
# operator's public key (from $OPERATOR_PUB_KEY at container startup) as the
# initial trusted signer.
#
# Modes:
#   - placeholder seed (no extra arg): scaffolds the auto-approving `example`
#     reviewer; intended to be replaced via `stamp bootstrap` on first clone.
#   - <seed-stamp-dir>: path on the SERVER (typically scp'd into /tmp first)
#     containing config.yml + reviewers/ + optional mirror.yml; the bare repo
#     is seeded directly with that .stamp/ config + a fresh empty initial
#     commit.
#   - --from-tarball <path>: path on the SERVER to a gzipped bare-clone of
#     the operator's existing repo. The tarball is extracted as the bare
#     repo, preserving the operator's full history + .stamp/ + trusted-keys.
#     Used by `stamp provision --migrate-existing` for brownfield migration.
#
set -e

usage() {
  echo "usage: new-stamp-repo <name> [<seed-stamp-dir> | --from-tarball <tarball-path>]" >&2
  exit 2
}

if [ $# -lt 1 ]; then
  usage
fi

NAME="$1"
SEED_DIR=""
FROM_TARBALL=""

case $# in
  1)
    : # placeholder seed
    ;;
  2)
    SEED_DIR="$2"
    ;;
  3)
    if [ "$2" != "--from-tarball" ]; then
      usage
    fi
    FROM_TARBALL="$3"
    # Constrain FROM_TARBALL to the documented client-side upload prefix
    # BEFORE any other validation. The EXIT trap below would otherwise
    # `rm -f` whatever path the caller named — a cross-tenant `rm`
    # primitive against everything under /srv/git that the `git` user
    # owns (every other team's repos). v4 audit M-S2.
    case "$FROM_TARBALL" in
      /tmp/stamp-migrate-*.tar.gz)
        ;;
      *)
        echo "error: --from-tarball must be at /tmp/stamp-migrate-*.tar.gz (got '$FROM_TARBALL')" >&2
        exit 2
        ;;
    esac
    # Realpath-resolve and re-check: a symlink at /tmp/stamp-migrate-x.tar.gz
    # whose target is outside /tmp would otherwise let the trap delete the
    # symlink target. readlink -f is portable across busybox (Alpine) and
    # GNU coreutils. Empty result on failure → reject.
    CANON_TARBALL=$(readlink -f "$FROM_TARBALL" 2>/dev/null || true)
    case "$CANON_TARBALL" in
      /tmp/*)
        ;;
      *)
        echo "error: --from-tarball '$FROM_TARBALL' resolves outside /tmp (canonical: '$CANON_TARBALL'); refusing" >&2
        exit 2
        ;;
    esac
    ;;
  *)
    usage
    ;;
esac

# Validate name shape: must start with [A-Za-z0-9_] and match
# [A-Za-z0-9._-]+. Same rules as the client-side validateRepoName in
# src/commands/serverRepo.ts and the sister scripts delete-stamp-repo
# and restore-stamp-repo. Without this, names like `../tmp/foo` would
# resolve to `/tmp/foo.git` and escape the /srv/git prefix; `.trash/foo`
# would inject a bare repo into the trash directory. The case+grep pair
# is deliberate — case is fast for the obvious bad shapes (path
# separators, leading dot/dash); grep -E catches everything else
# (whitespace, `;`, `$`, etc.) so direct-ssh callers without the TS
# wrapper get the same enforcement. Exit 2 for argument errors.
case "$NAME" in
  ""|"."|".."|*"/"*|*".."*|.*|-*)
    echo "error: invalid repo name '$NAME' (must start with [A-Za-z0-9_] and match [A-Za-z0-9._-]+)" >&2
    exit 2
    ;;
esac
if ! printf '%s' "$NAME" | grep -Eq '^[A-Za-z0-9_][A-Za-z0-9._-]*$'; then
  echo "error: invalid repo name '$NAME' (must start with [A-Za-z0-9_] and match [A-Za-z0-9._-]+)" >&2
  exit 2
fi

GIT_ROOT=/srv/git
REPO="$GIT_ROOT/${NAME}.git"

# Defensive: refuse to resolve to any of the protected paths even if the
# validator above somehow let one through. Mirrors delete-stamp-repo.
case "$REPO" in
  "$GIT_ROOT"|"$GIT_ROOT/"|"$GIT_ROOT/.trash"|"$GIT_ROOT/.trash/"|"$GIT_ROOT/.ssh-host-keys"|"$GIT_ROOT/.ssh-host-keys/")
    echo "error: refusing to act on protected path $REPO" >&2
    exit 1
    ;;
esac
# The setup-repo.sh script auto-discovers post-receive.cjs alongside
# the pre-receive path, so we pass the .cjs form here to enable it.
HOOK="/etc/stamp/pre-receive.cjs"
OPERATOR_KEY="/etc/stamp/operator.pub"

if [ -e "$REPO" ]; then
  echo "error: $REPO already exists" >&2
  exit 1
fi

if [ ! -f "$OPERATOR_KEY" ]; then
  echo "error: operator public key not found at $OPERATOR_KEY" >&2
  echo "set OPERATOR_PUB_KEY when launching the container" >&2
  exit 1
fi

# Suppress setup-repo.sh's own next-steps — it would print a `git clone <local
# path>` line that's wrong over SSH. We print a server-aware footer below.
export STAMP_SETUP_QUIET_NEXT_STEPS=1

if [ -n "$FROM_TARBALL" ]; then
  # Server-side cleanup of the operator-uploaded tarball. Lives here
  # (inside the new-stamp-repo wrapper) rather than as a separate
  # `ssh git@host rm /tmp/...` from the client because git-shell's
  # forced-command allowlist (commit 4b83960) only runs the wrappers
  # symlinked into /home/git/git-shell-commands/ — `rm` is not in
  # that set, so a client-side cleanup attempt silently no-ops and
  # the tarball persists. trap EXIT covers both successful extraction
  # and `set -e`-induced failure inside setup-repo.sh, so no stranded
  # tarballs in either case. The path constraint at arg-parse time
  # (above, in the case $#==3 branch) bounds the blast radius to the
  # client's own upload — without it, this trap would be a cross-tenant
  # `rm` primitive (v4 audit M-S2).
  trap 'rm -f "$FROM_TARBALL"' EXIT
  /usr/local/bin/setup-repo.sh "$REPO" "$HOOK" "$OPERATOR_KEY" --from-tarball "$FROM_TARBALL"
elif [ -n "$SEED_DIR" ]; then
  /usr/local/bin/setup-repo.sh "$REPO" "$HOOK" "$OPERATOR_KEY" "$SEED_DIR"
else
  /usr/local/bin/setup-repo.sh "$REPO" "$HOOK" "$OPERATOR_KEY"
fi

# SSH client-aware next steps. We don't know the exact host the operator used
# to SSH in (could be Railway TCP proxy, custom CNAME, localhost, etc.), so
# show <stamp-host> as a placeholder the user can substitute.
echo
echo "Next steps (substitute <stamp-host> with the SSH host you connected to):"
if [ -n "$FROM_TARBALL" ]; then
  echo "  1. Update local origin to: ssh://git@<stamp-host>${REPO}"
  echo "     (the bare already has your full history from the tarball — no push needed)"
  echo "  2. Continue with the normal stamp review/merge cycle for new commits"
elif [ -n "$SEED_DIR" ]; then
  echo "  1. Clone:        git clone ssh://git@<stamp-host>${REPO}"
  echo "  2. cd into the clone"
  echo "  3. Customize .stamp/reviewers/ as needed, then start the normal"
  echo "     stamp review/merge cycle."
else
  echo "  1. Clone:        git clone ssh://git@<stamp-host>${REPO}"
  echo "  2. cd into the clone"
  echo "  3. Run:          stamp bootstrap"
  echo
  echo "     Installs real reviewers (security/standards/product) and replaces"
  echo "     the placeholder in one command. \`stamp bootstrap --help\` for"
  echo "     options. To skip this step on future repos, scp your .stamp/"
  echo "     seed dir to /tmp/seed on the server and re-run with:"
  echo "       ssh git@<stamp-host> new-stamp-repo <name> /tmp/seed"
fi
